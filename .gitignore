# =============================================================================
# Project-specific
# =============================================================================

# Never commit generated game state or simulation output
output/
sim_results/

# Generated arcade metadata (built from git history at build time)
ts/src/games/game-metadata.json

# Intake zips are raw AI Studio exports; MANIFEST.md is tracked.
intake/**/*.zip

# Lua compiled bytecode (should never appear, but just in case)
*.luac

# Examples — pre-port originals and scratch work stay untracked;
# active standalone demos (embedUrl tier) need real version control.
examples/*
!examples/ledger/
!examples/shoal/
!examples/trinity-siege/

# Screenshots
screenshots/

# Saves
saves/
